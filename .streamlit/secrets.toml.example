# Copy this file to ".streamlit/secrets.toml" for local runs, and paste your
# real Groq key below. Do NOT commit the real secrets.toml (it is gitignored).
#
# On Streamlit Cloud you don't need this file: set GROQ_API_KEY in the app's
# "Secrets" settings in the dashboard instead.
GROQ_API_KEY = "your_groq_key_here"
